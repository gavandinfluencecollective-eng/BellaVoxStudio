{
  "entities": {
    "contact_messages": {
      "title": "Contact Messages",
      "description": "Messages submitted via the Contact Us form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the message was sent."
        }
      },
      "required": ["name", "email", "phone", "message", "createdAt"]
    },
    "users": {
      "title": "Users",
      "description": "Application users with credits, streaks, and roles.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role."
        },
        "credits": {
          "type": "integer",
          "description": "Current credit balance."
        },
        "streakDay": {
          "type": "integer",
          "description": "Current daily login streak."
        },
        "lastLoginDate": {
          "type": "string",
          "format": "date-time",
          "description": "Last timestamp the user claimed a daily reward."
        },
        "adsWatchedToday": {
          "type": "integer",
          "description": "Number of ads watched today."
        },
        "lastAdDate": {
          "type": "string",
          "format": "date-time",
          "description": "Last timestamp the user watched an ad."
        }
      },
      "required": ["email", "role", "credits", "streakDay", "lastLoginDate", "adsWatchedToday", "lastAdDate"]
    }
  },
  "firestore": {
    "/contact_messages/{messageId}": {
      "schema": "contact_messages",
      "description": "Collection of contact messages."
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "Collection of users and their roles."
    }
  }
}
